# .env.example

# Server environment
NODE_ENV=development

# Server port
PORT=YOUR_APP_PORT_NUMBER_HERE

# Client URL (for CORS)
CLIENT_URL=YOUR_CLIENT_URL_HERE

# MongoDB connection URI
MONGO_URI=YOUR_MONGODB_URI_HERE

# JWT secret key for authentication (minimum 64 chars recommended)
JWT_SECRET=YOUR_JWT_SECRET_HERE_MINIMUM_64_CHARS
JWT_REFRESH_SECRET=YOUR_REFRESH_SECRET_HERE_MINIMUM_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie secret
COOKIE_SECRET=YOUR_COOKIE_SECRET_HERE

